---
import type { Translations } from '../utils/i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const cards = [
  {
    key: 'atis',
    image: '/images/nearby-atist.jpg',
    alt: t['img.atist.alt'],
  },
  {
    key: 'adventure',
    image: '/images/nearby-mountain.png',
    alt: t['img.atist.alt'],
  },
  {
    key: 'church',
    image: '/images/church-st-john-01.png',
    alt: t['img.church.alt'],
  },
  {
    key: 'logistics',
    image: '/images/hero-atist-monument.jpg',
    alt: t['img.hero.alt'],
  },
] as const;
---

<section class="section section--surface" id="location">
  <div class="container">
    <div class="section__header">
      <h2>{t['location.title']}</h2>
      <p class="section__lead">{t['location.subtitle']}</p>
    </div>
    <div class="location-grid">
      {cards.map(({ key, image, alt }) => (
        <article class="location-card">
          <div class="location-card__media">
            <img src={image} alt={alt} loading="lazy" decoding="async" />
          </div>
          <div class="location-card__body">
            <h3>{t[`nearby.${key}.title`]}</h3>
            <p>{t[`nearby.${key}.text`]}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .location-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    align-items: stretch;
  }

  @media (min-width: 768px) {
    .location-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 1fr;
    }
  }

  .location-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .location-card__media {
    aspect-ratio: 4 / 3;
    width: 100%;
    flex-shrink: 0;
    background: linear-gradient(160deg, #e8dfd3 0%, #d4c4b0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    overflow: hidden;
  }

  .location-card__media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
  }

  .location-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: var(--space-md);
    gap: 0.5rem;
  }

  .location-card__body h3 {
    margin: 0;
    font-size: var(--text-lg);
    color: var(--color-primary);
  }

  .location-card__body p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }
</style>
