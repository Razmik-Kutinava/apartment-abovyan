---
import type { Translations } from '../utils/i18n';

interface Props {
  t: Translations;
}

const { t } = Astro.props;

const cards = [
  {
    key: 'atis',
    image: '/images/location/atis.jpg',
    alt: t['img.atist.alt'],
  },
  {
    key: 'adventure',
    image: '/images/location/adventure.jpg',
    alt: t['img.adventure.alt'],
  },
  {
    key: 'church',
    image: '/images/location/church.png',
    alt: t['img.church.alt'],
  },
  {
    key: 'logistics',
    image: '/images/location/logistics.webp',
    alt: t['img.logistics.alt'],
  },
] as const;
---

<section class="section section--surface" id="location">
  <div class="container">
    <div class="section__header">
      <h2>{t['location.title']}</h2>
      <p class="section__lead">{t['location.subtitle']}</p>
    </div>
    <ul class="location-grid" role="list">
      {cards.map(({ key, image, alt }) => (
        <li class="location-grid__cell">
          <article class="location-card">
            <div class="location-card__media">
              <img src={image} alt={alt} loading="lazy" decoding="async" width="600" height="600" />
            </div>
            <div class="location-card__body">
              <h3>{t[`nearby.${key}.title`]}</h3>
              <p>{t[`nearby.${key}.text`]}</p>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .location-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
  }

  .location-grid__cell {
    min-width: 0;
  }

  .location-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--color-surface);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    overflow: hidden;
    box-shadow: var(--shadow);
  }

  .location-card__media {
    aspect-ratio: 1 / 1;
    width: 100%;
    flex: 0 0 auto;
    background: #ebe4da;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .location-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .location-card__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: var(--space-md);
    min-height: 9.5rem;
  }

  .location-card__body h3 {
    margin: 0;
    font-size: var(--text-base);
    line-height: 1.3;
    color: var(--color-primary);
  }

  .location-card__body p {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.55;
  }

  @media (max-width: 540px) {
    .location-grid {
      grid-template-columns: 1fr;
    }

    .location-card__body {
      min-height: 0;
    }
  }
</style>
