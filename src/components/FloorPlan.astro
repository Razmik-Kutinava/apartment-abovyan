---
import type { Translations } from '../utils/i18n';
interface Props { t: Translations; }
const { t } = Astro.props;
---

<section class="section" id="floorplan">
  <div class="container">
    <div class="section__header">
      <h2>{t['floorplan.title']}</h2>
      <p class="section__lead">{t['floorplan.note']}</p>
    </div>
    <figure class="floorplan">
      <img
        src="/images/floorplan-78.jpg"
        alt={t['img.floorplan.alt']}
        loading="lazy"
        decoding="async"
        width="1200"
        height="900"
        class="floorplan__image"
      />
    </figure>
  </div>
</section>

<style>
  .floorplan {
    margin: 0;
    max-width: 720px;
  }
  .floorplan__image {
    width: 100%;
    height: auto;
    display: block;
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
</style>
