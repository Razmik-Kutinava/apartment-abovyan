---
import type { Translations } from '../utils/i18n';
interface Props { t: Translations; }
const { t } = Astro.props;
const specs = ['address', 'area', 'floor', 'view', 'balcony', 'condition', 'parquet'] as const;
---

<section class="section section--surface" id="solution">
  <div class="container">
    <div class="section__header">
      <h2>{t['solution.title']}</h2>
      <p class="section__lead">{t['solution.intro']}</p>
    </div>
    <h3 class="specs__title">{t['solution.specs_title']}</h3>
    <div class="specs">
      {specs.map((key) => (
        <div class="specs__item">{t[`spec.${key}`]}</div>
      ))}
    </div>
  </div>
</section>

<style>
  .specs__title {
    margin: 0 0 var(--space-md);
    font-size: var(--text-lg);
    color: var(--color-primary);
  }
  .specs {
    display: grid;
    gap: var(--space-sm);
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px) {
    .specs { grid-template-columns: repeat(2, 1fr); }
  }
  .specs__item {
    padding: var(--space-md);
    background: var(--color-bg);
    border-radius: var(--radius);
    font-size: var(--text-base);
  }
</style>
