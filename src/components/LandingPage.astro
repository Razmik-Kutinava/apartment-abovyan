---
import type { Locale, Translations } from '../utils/i18n';
import Header from './Header.astro';
import Hero from './Hero.astro';
import PainCards from './PainCards.astro';
import Mechanism from './Mechanism.astro';
import Consequences from './Consequences.astro';
import Solution from './Solution.astro';
import BuildingHeritage from './BuildingHeritage.astro';
import Gallery from './Gallery.astro';
import Distances from './Distances.astro';
import LocationCards from './LocationCards.astro';
import FloorPlan from './FloorPlan.astro';
import Offer from './Offer.astro';
import FAQ from './FAQ.astro';
import Footer from './Footer.astro';
import StickyWhatsApp from './StickyWhatsApp.astro';

interface Props {
  locale: Locale;
  t: Translations;
}
const { locale, t } = Astro.props;
---

<Header locale={locale} t={t} />
<main>
  <Hero t={t} />
  <PainCards t={t} />
  <Mechanism t={t} />
  <Consequences t={t} />
  <Solution t={t} />
  <BuildingHeritage t={t} />
  <Gallery t={t} />
  <Distances t={t} />
  <LocationCards t={t} />
  <FloorPlan t={t} />
  <Offer t={t} />
  <FAQ t={t} />
</main>
<Footer t={t} />
<StickyWhatsApp t={t} />
