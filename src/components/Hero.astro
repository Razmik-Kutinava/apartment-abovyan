---
import type { Translations } from '../utils/i18n';
import { buildWhatsAppUrl } from '../utils/whatsapp';

interface Props { t: Translations; }
const { t } = Astro.props;
const waUrl = buildWhatsAppUrl(t['hero.cta_prefill']);
---

<section class="hero" aria-label="Hero">
  <div class="hero__bg" role="img" aria-label={t['img.hero.alt']}></div>
  <div class="hero__overlay"></div>
  <div class="container hero__content">
    <span class="badge">{t['hero.badge']}</span>
    <h1>{t['hero.title']}</h1>
    <p class="hero__subtitle">{t['hero.subtitle']}</p>
    <p class="hero__benefit">{t['hero.benefit']}</p>
    <p class="hero__urgency">{t['hero.urgency']}</p>
    <a href={waUrl} class="btn btn--whatsapp hero__cta" target="_blank" rel="noopener noreferrer">
      {t['hero.cta']}
    </a>
    <p class="hero__spoiler">{t['hero.spoiler']}</p>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    padding-bottom: var(--space-xl);
    padding-top: 5rem;
  }
  .hero__bg {
    position: absolute;
    inset: 0;
    background: url('/images/hero-atist-monument.jpg') center / cover no-repeat;
    background-attachment: fixed;
  }
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(44,36,25,0.55) 0%, rgba(44,36,25,0.75) 60%, rgba(44,36,25,0.92) 100%);
  }
  .hero__content {
    position: relative;
    z-index: 1;
    color: #fff;
    max-width: 720px;
  }
  .hero__subtitle {
    font-size: var(--text-lg);
    opacity: 0.95;
  }
  .hero__benefit {
    font-size: var(--text-base);
    opacity: 0.9;
    margin-top: var(--space-md);
  }
  .hero__urgency {
    font-weight: 600;
    color: var(--color-gold);
    margin-top: var(--space-sm);
  }
  .hero__cta {
    margin-top: var(--space-md);
    font-size: var(--text-base);
  }
  .hero__spoiler {
    margin-top: var(--space-lg);
    opacity: 0.7;
    font-size: var(--text-sm);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__bg { background-attachment: scroll; }
  }
</style>
